          "name": "Batch - Write Then Append Heading",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/api/batch",
            "description": "Executes multiple API operations in one request.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operations\": [\n    {\n      \"route\": \"files/write\",\n      \"path\": \"Ideas/postman-batch.md\",\n      \"content\": \"## Log\\n\"\n    },\n    {\n      \"route\": \"headings/append\",\n      \"path\": \"Ideas/postman-batch.md\",\n      \"heading\": \"Log\",\n      \"content\": \"- Batch item\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
