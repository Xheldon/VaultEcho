API_TOKEN=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
APP_ENCRYPTION_KEY=replace-with-a-stable-random-secret
BIND_HOST=127.0.0.1
OBSIDIAN_VAULT_PATH=./vault

# Optional deployment settings. Runtime options such as Vault Root and Daily Note
# rules are configured in the web UI and stored in data/config.json.
#
# OBSIDIAN_VAULT_PATH must point to the local Vault directory already managed by
# Obsidian Headless Sync. Docker mounts it into the VaultEcho container as /vault.
# PORT=8787
# CONFIG_PATH=/data/config.json
