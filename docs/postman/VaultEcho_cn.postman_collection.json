              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/api/files/create",
            "description": "Runs safe JSON Vault Script after the primary create operation.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"path\": \"Ideas/postman-script-note.md\",\n  \"content\": \"Created with script.\",\n  \"ifExists\": \"overwrite\",\n  \"script\": {\n    \"operations\": [\n      {\n        \"op\": \"append\",\n        \"path\": \"{{dailyNote}}\",\n        \"content\": \"\\n- Created postman-script-note.md from Postman script\\n\"\n      }\n    ]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
